{
  "extends": "@repo/config/typescript/base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "outDir": "./dist",
    "paths": {
      "@/*": ["src/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "strictNullChecks": true
  },
  "include": [
    "src",
    "vite.config.ts",
    "../../packages/config/src/request/request.ts"
  ]
}
